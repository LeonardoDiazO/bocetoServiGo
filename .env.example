# ==============================================
# VARIABLES DE ENTORNO - ServiGo
# ==============================================
# Copia este archivo como .env y completa los valores.
# NUNCA subas el archivo .env real a GitHub.

# Google Gemini API Key (Genkit AI)
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (si usas Firebase directamente en el cliente)
# Obtén estos valores en: https://console.firebase.google.com -> Project Settings -> General
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
